{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.bigtable",
  "name": "Bigtable Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "Bigtable Connector contributes the Bigtable database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-bigtable",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "bigtable.connector",
        "engine": "bigtable",
        "label": "Bigtable",
        "aliases": [
          "bigtable",
          "Bigtable"
        ],
        "defaultPort": 443,
        "wire": "bigtable",
        "module": "bigtable.driver",
        "features": [
          "metadata",
          "streaming"
        ]
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "bigtable.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
